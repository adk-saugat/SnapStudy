FROM golang:1.25-alpine AS builder

WORKDIR /app

COPY server/go.mod server/go.sum ./
RUN go mod download

COPY server/ ./
RUN CGO_ENABLED=0 GOOS=linux go build -o /snapstudy-server ./cmd/server

FROM alpine:3.21

RUN apk add --no-cache ca-certificates

COPY --from=builder /snapstudy-server /snapstudy-server

EXPOSE 8080

CMD ["/snapstudy-server"]
